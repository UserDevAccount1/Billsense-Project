{
  "mcpServers": {
    "firebase": {
      "command": "npx",
      "args": ["-y", "firebase-tools@latest", "experimental:mcp"],
      "env": {
        "FIREBASE_PROJECT_ID": "bill-sense-aec6b",
        "GOOGLE_APPLICATION_CREDENTIALS": "D:/PROJECTS/BillSense/admin-panel/serviceAccountKey.json"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "billsense-cpanel": {
      "command": "node",
      "args": ["./tools/cpanel-mcp/server.mjs"],
      "env": {
        "CPANEL_HOST": "billsense.dev-environment.site",
        "CPANEL_PORT": "2083",
        "CPANEL_USER": "${CPANEL_USER}",
        "CPANEL_TOKEN": "${CPANEL_TOKEN}",
        "CPANEL_STRICT_SSL": "false"
      }
    }
  }
}
