{
  "mcpServers": {
    "firebase": {
      "command": "npx",
      "args": ["-y", "firebase-tools@latest", "experimental:mcp"],
      "env": {
        "FIREBASE_PROJECT_ID": "bill-sense-aec6b",
        "GOOGLE_APPLICATION_CREDENTIALS": "D:/PROJECTS/BillSense/admin-panel/serviceAccountKey.json"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "cpanel": {
      "command": "node",
      "args": ["./tools/ringo380-cpanel-mcp/dist/index.js"],
      "env": {
        "CPANEL_HOSTNAME": "billsense.dev-environment.site",
        "CPANEL_PORT": "2083",
        "CPANEL_SSL": "true",
        "CPANEL_USERNAME": "${CPANEL_USERNAME}",
        "CPANEL_API_TOKEN": "${CPANEL_API_TOKEN}"
      }
    }
  }
}
