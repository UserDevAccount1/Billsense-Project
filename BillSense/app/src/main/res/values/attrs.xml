<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="ArcMenu">
        <attr name="radius" format="dimension"/>
        <attr name="startAngle" format="float"/>
        <attr name="sweepAngle" format="float"/>
    </declare-styleable>
    <declare-styleable name="CornerFrameView">
        <attr name="cfv_cornerRadius" format="dimension" />
        <attr name="cfv_strokeWidth" format="dimension" />
        <attr name="cfv_frameColor" format="color" />
    </declare-styleable>
    <declare-styleable name="ThreeDotsView">
        <attr name="dotRadius" format="dimension" />
        <attr name="dotSpacing" format="dimension" />
        <attr name="dotColor" format="color" />
        <attr name="animationDuration" format="integer" />
    </declare-styleable>
</resources>