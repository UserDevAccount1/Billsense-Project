<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginTop="4dp"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"> <!-- For ripple effect on click -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Container for Title and Time -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/notification_title_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:maxLines="1"
                android:fontFamily="@font/poppins_bold"
                android:layout_toStartOf="@+id/notification_time_tv"
                android:text="Notification Title"
                android:textAppearance="?attr/textAppearanceSubtitle1"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/notification_time_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:fontFamily="@font/poppins_light"
                android:text="10:30 AM"
                android:textAppearance="?attr/textAppearanceCaption"
                android:textSize="11sp" />

        </RelativeLayout>

        <TextView
            android:id="@+id/notification_body_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="marquee"
            android:maxLines="2"
            android:fontFamily="@font/poppins"
            android:text="This is the body of the notification. It can contain more details about the alert or message."
            android:textAppearance="?attr/textAppearanceBody2"
            android:textSize="14sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>