<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/rounded_dialog_bg"
    android:padding="20dp">

    <TextView
        android:id="@+id/title_txt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="@string/are_you_sure_you_want_to_logout"
        android:layout_margin="10dp"
        android:textSize="18sp"
        android:textAlignment="center"
        android:fontFamily="@font/poppins_bold"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/yes_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_img_bg"
        app:layout_constraintTop_toBottomOf="@id/title_txt"
        android:layout_margin="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/no_btn"
        app:layout_constraintBottom_toBottomOf="parent"
        android:text="@string/yes"
        android:fontFamily="@font/poppins_bold"
        android:textStyle="bold"
        android:textSize="16sp"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/no_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_img_bg"
        app:layout_constraintTop_toBottomOf="@id/title_txt"
        android:layout_margin="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="@string/no"
        android:fontFamily="@font/poppins_bold"
        app:layout_constraintStart_toEndOf="@id/yes_btn"
        app:layout_constraintBottom_toBottomOf="parent"
        android:textStyle="bold"
        android:textSize="16sp"
        />


</androidx.constraintlayout.widget.ConstraintLayout>