<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_dialog_bg"
    android:backgroundTint="@color/colorPrimary"
    android:padding="10dp">

    <ImageView
        android:id="@+id/video_detection_iv"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_margin="10dp"
        android:contentDescription="@string/video_detection"
        android:src="@drawable/video_detection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/video_detection_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:fontFamily="@font/poppins_bold"
        android:padding="10dp"
        android:text="@string/video_detection"
        android:textColor="@color/text_color_white"
        android:textSize="25sp"
        app:layout_constraintBottom_toBottomOf="@id/video_detection_iv"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/video_detection_iv"
        app:layout_constraintTop_toTopOf="@id/video_detection_iv" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:fillViewport="true"
        android:layout_marginBottom="15dp"
        app:layout_constraintBottom_toTopOf="@id/begin_detection_btn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/video_detection_title">

        <TextView
            android:id="@+id/video_detection_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:padding="5dp"
            android:textColor="@color/text_color_black"
            android:fontFamily="@font/poppins"/>

    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/begin_detection_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/begin_detection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_margin="10dp"
        android:background="@drawable/btn_bg"
        android:textAllCaps="false"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:textSize="16sp"
        android:fontFamily="@font/poppins"
        />


</androidx.constraintlayout.widget.ConstraintLayout>