<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_compare_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.CompareBillActivity">

    <!-- Top Floating Button Panel -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/button_panel_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="8dp"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <HorizontalScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/buttons_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp">

                <!-- Switch Bill -->
                <LinearLayout
                    android:id="@+id/switch_bill_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/switch_bill"
                        android:textSize="10sp"
                        tools:ignore="SmallSp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_bill"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp" />
                </LinearLayout>

                <!-- Next Bill -->
                <LinearLayout
                    android:id="@+id/next_bill_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/next_bill"
                        android:textSize="10sp"
                        tools:ignore="SmallSp" />

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="@string/next_bill"
                        android:src="@drawable/ic_next_bill" /> <!-- Replace with your actual icon -->
                </LinearLayout>

                <!-- Opacity -->
                <LinearLayout
                    android:id="@+id/opacity_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/opacity"
                        android:textSize="10sp"
                        tools:ignore="SmallSp" />

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="@string/opacity"
                        android:src="@drawable/ic_opacity" /> <!-- Replace with your actual icon -->
                </LinearLayout>

                <!-- Rotate -->
                <LinearLayout
                    android:id="@+id/rotate_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/rotate"
                        android:textSize="10sp"
                        tools:ignore="SmallSp" />

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="@string/rotate"
                        android:src="@drawable/ic_rotate" /> <!-- Replace with your actual icon -->
                </LinearLayout>

                <!-- Hide Controls -->
                <LinearLayout
                    android:id="@+id/hide_controls_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <TextView
                        android:id="@+id/controls_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hide_controls"
                        android:textSize="10sp"
                        tools:ignore="SmallSp" />

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="@string/hide_controls"
                        android:src="@drawable/ic_hide_control" /> <!-- Replace with your actual icon -->
                </LinearLayout>

                <!-- Go Back -->
                <LinearLayout
                    android:id="@+id/go_back_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/go_back"
                        android:textSize="10sp"
                        tools:ignore="SmallSp" />

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="@string/go_back"
                        android:src="@drawable/ic_back" /> <!-- Replace with your actual icon -->
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- Guideline for the draggable divider -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/vertical_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" /> <!-- Initial split at 50% -->

    <!-- Left Image View (User Uploaded) -->
    <!-- Using a FrameLayout to help with potential clipping/overlay if needed by custom view -->
    <FrameLayout
        android:id="@+id/left_image_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/vertical_guideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/image_view_user_uploaded"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            tools:srcCompat="@tools:sample/backgrounds/scenic" /> <!-- Placeholder background/image -->
    </FrameLayout>

    <!-- Right Image View (Original/Real One) -->
    <FrameLayout
        android:id="@+id/right_image_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/vertical_guideline"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/image_view_original"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            tools:srcCompat="@tools:sample/backgrounds/scenic" /> <!-- Placeholder background/image -->

    </FrameLayout>

    <!-- Draggable Divider View (Optional Visual Handle) -->
    <!-- This view itself won't be draggable without code, but it represents the line -->
    <View
        android:id="@+id/divider_line_handle"
        android:layout_width="8dp"
        android:layout_height="0dp"
        android:layout_marginStart="-2dp"
        android:layout_marginEnd="-2dp"
        android:background="@android:color/black"
        android:elevation="1dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/left_image_container"
        app:layout_constraintEnd_toStartOf="@id/right_image_container"
        app:layout_constraintStart_toEndOf="@id/left_image_container"
        app:layout_constraintTop_toTopOf="@id/left_image_container" /> <!-- Ensure it's above images if they overlap -->

</androidx.constraintlayout.widget.ConstraintLayout>