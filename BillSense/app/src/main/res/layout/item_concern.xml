<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardElevation="4dp"
    app:cardCornerRadius="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Ticket Number -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/textViewTicketLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ticket_no_label"
            android:textAppearance="?attr/textAppearanceCaption"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/textViewTicketNo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textAppearance="?attr/textAppearanceBody2"
            android:textStyle="bold"
            tools:text="TICKET-12345678"
            app:layout_constraintStart_toEndOf="@id/textViewTicketLabel"
            app:layout_constraintTop_toTopOf="@id/textViewTicketLabel"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- User Name -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/textViewUserLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/user_name_label"
            android:textAppearance="?attr/textAppearanceCaption"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textViewTicketNo" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/textViewUserName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textAppearance="?attr/textAppearanceBody2"
            tools:text="John Doe"
            app:layout_constraintStart_toEndOf="@id/textViewUserLabel"
            app:layout_constraintTop_toTopOf="@id/textViewUserLabel"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Status -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/textViewStatusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/status_label"
            android:textAppearance="?attr/textAppearanceCaption"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textViewUserLabel" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/textViewStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textAppearance="?attr/textAppearanceBody2"
            tools:text="Status"
            app:layout_constraintStart_toEndOf="@id/textViewStatusLabel"
            app:layout_constraintTop_toTopOf="@id/textViewStatusLabel"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Date -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/textViewDateLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/date_label"
            android:textAppearance="?attr/textAppearanceCaption"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textViewStatusLabel" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/textViewDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textAppearance="?attr/textAppearanceBody2"
            tools:text="2024-07-26 10:30 AM"
            app:layout_constraintStart_toEndOf="@id/textViewDateLabel"
            app:layout_constraintTop_toTopOf="@id/textViewDateLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Concern -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/textViewConcernLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/concern_label"
            android:textAppearance="?attr/textAppearanceSubtitle2"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textViewDate" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/textViewConcern"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceBody1"
            android:maxLines="3"
            android:ellipsize="end"
            tools:text="This is a detailed description of the concern that the user has submitted. It might be a bit long, so we are limiting it to a few lines and adding an ellipsis."
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textViewConcernLabel"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Action Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonDelete"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/delete"
            app:icon="@drawable/ic_delete"
            app:iconTint="?attr/colorError"
            android:textColor="?attr/colorError"
            app:strokeColor="?attr/colorError"
            app:layout_constraintEnd_toStartOf="@id/buttonChat"
            app:layout_constraintTop_toBottomOf="@id/textViewConcern"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonChat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/chat"
            app:icon="@drawable/ic_chat"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textViewConcern"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>