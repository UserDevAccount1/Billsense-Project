<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/scan_bg_clr"
    android:fitsSystemWindows="true"
    tools:context=".scan.video.VideoScanActivity">

    <!-- CameraX PreviewView -->
    <androidx.camera.view.PreviewView
        android:id="@+id/videoPreviewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Controls Bar (Unchanged) -->
    <LinearLayout
        android:id="@+id/video_top_controls_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <!-- ... your existing focus and flash controls ... -->
    </LinearLayout>

    <!-- Dotted Frame (Unchanged) -->
    <com.app.billsense.utils.DottedFrameView
        android:id="@+id/video_dotted_frame_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="6dp"
        android:elevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Instructions & Tips (Unchanged) -->
    <TextView
        android:id="@+id/video_instructions_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/rounded_background_opaque_white"
        android:elevation="4dp"
        android:gravity="center"
        android:padding="12dp"
        android:text="@string/video_instruction_text"
        android:textColor="@android:color/black"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@+id/video_tips_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <TextView
        android:id="@+id/video_tips_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/rounded_background_opaque_white_light_gray"
        android:elevation="4dp"
        android:gravity="center"
        android:padding="10dp"
        android:text="@string/video_tips_text"
        android:textColor="#444444"
        android:textSize="11sp"
        app:layout_constraintBottom_toTopOf="@+id/start_video_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Start Video Button (Unchanged) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/start_video_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#28a745"
        android:elevation="4dp"
        android:paddingStart="32dp"
        android:paddingTop="12dp"
        android:paddingEnd="32dp"
        android:paddingBottom="12dp"
        android:text="Start Video"
        android:textSize="16sp"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ======================= NEW/MODIFIED SECTION ======================= -->

    <!-- NEW: Show/Hide Info Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/show_info_button"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/red"
        android:elevation="4dp"
        android:text="@string/show_info"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- MODIFIED: Side Panel with all new fields -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/side_cards_layout"
        android:layout_width="190dp"
        android:layout_height="0dp"
        android:layout_marginTop="?attr/actionBarSize"
        android:layout_marginBottom="?attr/actionBarSize"
        android:background="#1A000000"
        android:elevation="8dp"
        android:fillViewport="true"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- Real-Time Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/bill_info_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#E6FFFFFF"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Live Analysis"
                        android:textColor="@android:color/black"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <!-- New Fields based on logs -->
                    <TextView
                        android:id="@+id/frames_processed_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/black"
                        android:textSize="11sp"
                        tools:text="Frames: 23" />

                    <TextView
                        android:id="@+id/denomination_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/black"
                        android:textSize="11sp"
                        tools:text="Denomination: 1000" />

                    <TextView
                        android:id="@+id/authenticity_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/black"
                        android:textSize="11sp"
                        tools:text="Authenticity: GENUINE"/>

                    <TextView
                        android:id="@+id/current_confidence_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/black"
                        android:textSize="11sp"
                        tools:text="Current Conf: 68.5%" />

                    <TextView
                        android:id="@+id/best_confidence_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/black"
                        android:textSize="11sp"
                        tools:text="Best Conf: 82.3%" />

                    <TextView
                        android:id="@+id/features_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@android:color/black"
                        android:textSize="11sp"
                        tools:text="Features: 3" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quality Metrics Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/quality_metrics_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#E6FFFFFF"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/image_quality"
                        android:textColor="@android:color/black"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <!-- New Fields for Quality -->
                    <TextView
                        android:id="@+id/quality_status_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/black"
                        android:textSize="11sp"
                        tools:text="Status: EXCELLENT (77.4)"/>
                    <TextView
                        android:id="@+id/sharpness_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/black"
                        android:textSize="11sp"
                        tools:text="Sharpness: 2582.45"/>
                    <TextView
                        android:id="@+id/brightness_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/black"
                        android:textSize="11sp"
                        tools:text="Brightness: 49.42"/>
                    <TextView
                        android:id="@+id/contrast_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/black"
                        android:textSize="11sp"
                        tools:text="Contrast: 68.61"/>

                    <TextView
                        android:id="@+id/quality_feedback_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@android:color/black"
                        android:textSize="11sp"
                        tools:text="Feedback: N/A"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
