<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/grey_light"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Collapsed Header -->
        <LinearLayout
            android:id="@+id/collapsed_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="?attr/selectableItemBackground">

            <!-- Thumbnail -->
            <ImageView
                android:id="@+id/scan_thumbnail_iv"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerCrop"
                android:src="@drawable/scan_bill"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.Button.Rounded"
                android:contentDescription="Scan thumbnail" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <!-- Status badge + scan type -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/status_badge_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rounded_bg"
                        android:backgroundTint="@color/green"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:fontFamily="@font/poppins"
                        android:textStyle="bold"
                        tools:text="GENUINE" />

                    <TextView
                        android:id="@+id/scan_type_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/grey_medium"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins"
                        tools:text="Standard Scan" />

                </LinearLayout>

                <!-- Date -->
                <TextView
                    android:id="@+id/scan_date_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/grey_medium"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins"
                    tools:text="Mar 23, 2026 at 10:30 AM" />

            </LinearLayout>

            <!-- Expand/collapse arrow -->
            <ImageView
                android:id="@+id/expand_arrow_iv"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/arrow_down_float"
                android:contentDescription="Expand"
                android:alpha="0.6" />

        </LinearLayout>

        <!-- Expanded Details -->
        <LinearLayout
            android:id="@+id/expanded_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/grey_light"
                android:layout_marginBottom="8dp" />

            <!-- Scanned Image -->
            <ImageView
                android:id="@+id/scanned_image_iv"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="fitCenter"
                android:background="@color/grey_light"
                android:contentDescription="Scanned bill image"
                android:visibility="gone" />

            <!-- Confidence Score -->
            <LinearLayout
                android:id="@+id/confidence_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confidence Score"
                    android:textColor="@color/text_color_black"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <ProgressBar
                        android:id="@+id/confidence_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="12dp"
                        android:layout_weight="1"
                        android:max="100"
                        android:progressTint="@color/green" />

                    <TextView
                        android:id="@+id/confidence_text_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/text_color_black"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins"
                        android:textStyle="bold"
                        tools:text="95.5%" />

                </LinearLayout>

            </LinearLayout>

            <!-- Security Features -->
            <LinearLayout
                android:id="@+id/security_features_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Security Features"
                    android:textColor="@color/text_color_black"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/security_features_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Recommendation -->
            <TextView
                android:id="@+id/recommendation_tv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_bg"
                android:backgroundTint="@color/grey_light"
                android:padding="10dp"
                android:textColor="@color/text_color_black"
                android:textSize="13sp"
                android:fontFamily="@font/poppins"
                android:visibility="gone"
                tools:text="Recommendation: This bill appears to be genuine." />

            <!-- Processing Info -->
            <TextView
                android:id="@+id/processing_info_tv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/grey_medium"
                android:textSize="11sp"
                android:fontFamily="@font/poppins"
                android:visibility="gone"
                tools:text="Processed in 1.2s | Model: YOLOv8-OBB" />

            <!-- View Full Report button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/view_full_report_btn"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/poppins"
                android:text="View Full Report"
                android:textAllCaps="false"
                android:textColor="@color/colorPrimary"
                app:strokeColor="@color/colorPrimary" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
