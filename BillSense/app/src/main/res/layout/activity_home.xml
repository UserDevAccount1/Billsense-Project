<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    tools:context=".activities.HomeActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profile_img"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/agent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:civ_border_color="@color/black"
            app:civ_border_width="2dp"
            app:civ_border_overlay="true"/>

        <TextView
            android:id="@+id/welcome_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:fontFamily="@font/poppins"
            android:text="@string/welcome"
            android:textColor="@color/text_color_black"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/profile_img"
            app:layout_constraintTop_toTopOf="@id/profile_img" />

        <TextView
            android:id="@+id/name_txt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:fontFamily="@font/poppins"
            android:text="@string/name"
            android:textColor="@color/text_color_black"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="5dp"
            app:layout_constraintBottom_toBottomOf="@id/profile_img"
            app:layout_constraintEnd_toStartOf="@id/notification_img"
            app:layout_constraintStart_toEndOf="@id/profile_img"/>

        <ImageView
            android:id="@+id/notification_img"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/notification"
            app:layout_constraintEnd_toStartOf="@id/view_profile"
            app:layout_constraintTop_toTopOf="@id/view_profile" />

        <ImageView
            android:id="@+id/view_profile"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_menu"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.search.SearchBar
            android:id="@+id/search_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/search"
            app:backgroundTint="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profile_img" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:layout_above="@id/bottom_bar"
        android:layout_below="@id/top_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Announcements Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="Announcements"
                android:textColor="@color/text_color_black"
                android:layout_marginTop="10dp"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/announcement_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/grey_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- No announcements placeholder -->
                    <TextView
                        android:id="@+id/no_announcements_tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="No announcements"
                        android:textColor="@color/grey_medium"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"
                        android:visibility="visible" />

                    <!-- Announcement content container -->
                    <LinearLayout
                        android:id="@+id/announcement_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/announcement_priority_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/rounded_bg"
                                android:backgroundTint="@color/colorPrimary"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:text="INFO"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:fontFamily="@font/poppins"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/announcement_date_tv"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="end"
                                android:textColor="@color/grey_medium"
                                android:textSize="11sp"
                                android:fontFamily="@font/poppins"
                                tools:text="Mar 23, 2026" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/announcement_title_tv"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/text_color_black"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins_bold"
                            tools:text="Welcome to BillSense" />

                        <TextView
                            android:id="@+id/announcement_message_tv"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:maxLines="3"
                            android:ellipsize="end"
                            android:textColor="@color/grey_medium"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins"
                            tools:text="BillSense uses AI-powered detection to help you verify Philippine banknotes." />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Scan History Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="@string/scan_history"
                android:textColor="@color/text_color_black"
                android:layout_marginTop="14dp"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/scan_history_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/grey_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- No scan history placeholder -->
                    <TextView
                        android:id="@+id/no_scan_history_tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/no_scan_history_found"
                        android:textColor="@color/grey_medium"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins"
                        android:paddingTop="24dp"
                        android:paddingBottom="24dp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <!-- Recent scans preview (vertical, shows latest 2) -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/scan_history_rv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_scan_report" />

                    <!-- View All button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/view_all_scan_history_btn"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="View All Scan History"
                        android:textColor="@color/colorPrimary"
                        android:fontFamily="@font/poppins"
                        android:textAllCaps="false"
                        app:icon="@android:drawable/ic_menu_more"
                        app:iconGravity="end"
                        app:iconTint="@color/colorPrimary" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_alignParentBottom="true">

        <com.google.android.material.bottomappbar.BottomAppBar
            android:id="@+id/bottomAppBar"
            style="@style/Widget.MaterialComponents.BottomAppBar.Colored"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            app:fabCradleMargin="15dp"
            app:fabCradleRoundedCornerRadius="10dp"
            app:fabCradleVerticalOffset="10dp"
            app:hideOnScroll="true" />

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigationView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@color/colorPrimary"
            app:itemIconSize="30dp"
            app:itemIconTint="@color/white"
            app:itemPaddingBottom="10dp"
            app:itemPaddingTop="10dp"
            app:itemTextColor="@color/white"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_menu" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_scan_bill"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/scan_bill"
            app:backgroundTint="@color/colorPrimary"
            app:fabCustomSize="70dp"
            app:layout_anchor="@id/bottomAppBar"
            app:maxImageSize="40dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.Button.Rounded"
            app:tint="@color/white" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- FAB Speed Dial overlay - covers entire screen -->
    <View
        android:id="@+id/fab_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:elevation="8dp" />

    <!-- Radial FAB Container - FrameLayout centered at bottom for radial positioning -->
    <FrameLayout
        android:id="@+id/fab_radial_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentBottom="true"
        android:elevation="10dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone">

        <!-- Standard Scan (150 degrees) -->
        <LinearLayout
            android:id="@+id/fab_standard_scan_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="100dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="invisible">

            <TextView
                android:id="@+id/label_standard_scan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="@drawable/fab_label_bg"
                android:text="@string/standard_scan"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:fontFamily="@font/poppins"
                android:alpha="0" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_standard_scan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/standard_scan"
                android:src="@drawable/ic_camera"
                app:backgroundTint="@color/colorPrimary"
                app:fabSize="mini"
                app:tint="@color/white" />
        </LinearLayout>

        <!-- Multi Scan (120 degrees) -->
        <LinearLayout
            android:id="@+id/fab_multi_scan_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="100dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="invisible">

            <TextView
                android:id="@+id/label_multi_scan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="@drawable/fab_label_bg"
                android:text="@string/multi_scan"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:fontFamily="@font/poppins"
                android:alpha="0" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_multi_scan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/multi_scan"
                android:src="@drawable/ic_grid"
                app:backgroundTint="@color/colorPrimary"
                app:fabSize="mini"
                app:tint="@color/white" />
        </LinearLayout>

        <!-- Video Scan (60 degrees) -->
        <LinearLayout
            android:id="@+id/fab_video_scan_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="100dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="invisible">

            <TextView
                android:id="@+id/label_video_scan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="@drawable/fab_label_bg"
                android:text="@string/video_scan"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:fontFamily="@font/poppins"
                android:alpha="0" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_video_scan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/video_scan"
                android:src="@drawable/ic_videocam"
                app:backgroundTint="@color/colorPrimary"
                app:fabSize="mini"
                app:tint="@color/white" />
        </LinearLayout>

        <!-- Upload Image (30 degrees) -->
        <LinearLayout
            android:id="@+id/fab_upload_scan_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="100dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="invisible">

            <TextView
                android:id="@+id/label_upload_scan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="@drawable/fab_label_bg"
                android:text="@string/upload_image"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:fontFamily="@font/poppins"
                android:alpha="0" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_upload_scan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/upload_image"
                android:src="@drawable/ic_image_upload"
                app:backgroundTint="@color/colorPrimary"
                app:fabSize="mini"
                app:tint="@color/white" />
        </LinearLayout>

    </FrameLayout>

</RelativeLayout>
