<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
    <item android:top="0dp" android:left="0dp" android:right="27dp" android:bottom="27dp"> <!-- Adjust thickness by changing right/bottom -->
        <shape android:shape="line">
            <stroke android:width="3dp" android:color="#CCFFFFFF"/> <!-- 80% white -->
        </shape>
    </item>
    <item android:top="0dp" android:left="0dp" android:right="27dp" android:bottom="27dp"
        android:rotation="90" android:pivotX="0%" android:pivotY="0%">
        <shape android:shape="line">
            <stroke android:width="3dp" android:color="#CCFFFFFF"/>
        </shape>
    </item>
</layer-list>